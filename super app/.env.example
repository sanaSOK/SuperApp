# ─── Server ───────────────────────────────────────────
PORT=3001

# ─── JWT ──────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── Database ─────────────────────────────────────────
DB_PATH=./database/egov.db

# ─── Gmail SMTP ───────────────────────────────────────
# Go to Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# ─── Telegram Bot ─────────────────────────────────────
# Chat with @BotFather on Telegram to create a bot and get the token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ─── Twilio SMS ───────────────────────────────────────
# Sign up at twilio.com for these credentials
TWILIO_ACCOUNT_SID=your-twilio-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=your-twilio-number-here
